## Security hardening – Supply-chain attack mitigation
## See: SECURITY.md for full policy

# Require packages to have been published for at least 7 days before install
min-release-age=7

# Prevent lifecycle scripts from running during install (blocks postinstall malware)
ignore-scripts=true

# Always generate / verify the lockfile on install
package-lock=true

# Fail if the lockfile would need to be updated (CI-safe)
# Uncomment in CI:
# lockfile-version=3

# Prefer exact versions when using `npm install <pkg>`
save-exact=true

# Run npm audit automatically on install
audit=true
