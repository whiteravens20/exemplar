# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_SERVER_ID=your_server_id_for_ai_assistant

# n8n Configuration
N8N_WORKFLOW_URL=https://your-n8n-instance.com/webhook/workflow
N8N_API_KEY=your_n8n_api_key_here

# Bot Configuration
HARDCODED_MENTION_RESPONSE=Cześć! Jestem asystentem AI. Wyślij mi wiadomość prywatną, aby ze mną porozmawiać.

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=discord_bot
DB_USER=bot_user
DB_PASSWORD=your_secure_password_here
DB_SSL=false
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000

# Health Check
HEALTH_CHECK_PORT=3000

# Moderation
ALLOWED_ROLES_FOR_AI=role_id_1,role_id_2,role_id_3
MOD_LOG_CHANNEL_ID=                    # Optional: channel ID for moderation action logs
RESTRICTED_RESPONSE=Nie masz uprawnień do użycia tej funkcji. Skontaktuj się z administratorami.

# AI moderation (issue #16) — see docs/AI_MODERATION.md for full setup.
# off    : disabled (default)
# shadow : analyse messages but only log verdicts to MOD_LOG_CHANNEL_ID — no actions
# enforce: dispatch actions for real (warn / timeout / delete)
AI_MODERATION_MODE=off
# Separate n8n workflow URL for moderation requests (X-API-Key reuses N8N_API_KEY).
# If unset, AI moderation stays disabled regardless of AI_MODERATION_MODE.
N8N_MODERATION_WORKFLOW_URL=
# Comma-separated channel IDs that AI moderation actively analyses.
# Strict opt-in: an empty / unset list means NO channels are analysed (the bot
# stays out of news / announcement / read-only channels by default).
AI_MOD_INCLUDE_CHANNELS=
# Comma-separated role IDs whose holders are skipped (mods, trusted bots, etc.).
AI_MOD_EXEMPT_ROLES=
# Active-warning count that triggers an auto-mute (default 3). Mute lasts until
# the oldest active warning expires, capped at Discord's 28-day timeout maximum.
AI_MOD_MUTE_THRESHOLD=3
# Lifetime (historical) warning count that triggers an auto-ban (default 100).
AI_MOD_BAN_THRESHOLD=100
# Per-user cooldown (ms) between AI moderation n8n calls. Stops a single user
# from triggering unbounded concurrent webhook calls during a burst of
# messages in an enrolled channel. Default 5000 (5s). Set to 0 to disable.
AI_MOD_USER_COOLDOWN_MS=5000
# Server-specific rules surfaced to the AI moderation LLM. When empty the LLM
# falls back to the generic community baseline in its system prompt. Use \n in
# the value to embed line breaks (dotenv treats the string literally).
MOD_RULES_TEXT=

# Error Messages
# The bot automatically detects the type of error and displays the appropriate message:
# - n8n unavailable: "⚠️ The backend is currently unavailable. Please try again in a moment."
# - Timeout: "⏱️ Request timed out. Your message took too long to process."
# - Workflow not found (404): "⚠️ Backend workflow not found. Please check n8n configuration."
# - Authorization error (401/403): "🔒 Backend authentication failed. Please check API key configuration."
# - General error: "❌ Error processing your message. Please try again later."
# You can change these messages in src/config/response-templates.js

# Environment
NODE_ENV=production
