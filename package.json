{
  "name": "discord-ai-bot",
  "version": "3.0.6",
  "description": "Discord Bot with n8n AI Assistant integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts --exec \"npx tsc && node dist/index.js\"",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "deploy-commands": "node dist/deploy-commands.js",
    "release-package": "bash scripts/create-release-package.sh",
    "lint": "eslint src --fix",
    "migrate:up": "npx tsx scripts/migrate.ts up",
    "migrate:down": "npx tsx scripts/migrate.ts down",
    "db:seed": "bash scripts/seed-test-data.sh"
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "n8n",
    "moderation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "1.15.0",
    "discord.js": "14.26.3",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "pg": "8.20.0",
    "undici": "8.1.0",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "25.6.0",
    "@types/pg": "8.20.0",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "nodemon": "3.1.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vitest": "4.1.4"
  },
  "overrides": {
    "minimatch": "10.2.4",
    "follow-redirects": "1.16.0",
    "postcss": "8.5.10"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.12.1"
  }
}
