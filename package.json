{
  "name": "discord-ai-bot",
  "version": "3.0.7",
  "description": "Discord Bot with n8n AI Assistant integration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-dashboard-assets.mjs",
    "start": "node dist/index.js",
    "dev": "nodemon --watch src --ext ts,html,css,js --exec \"npx tsc && node scripts/copy-dashboard-assets.mjs && node dist/index.js\"",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "deploy-commands": "node dist/deploy-commands.js",
    "release-package": "bash scripts/create-release-package.sh",
    "lint": "eslint src --fix",
    "migrate:up": "node dist/scripts/migrate.js up",
    "migrate:down": "node dist/scripts/migrate.js down",
    "db:seed": "bash scripts/seed-test-data.sh"
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "n8n",
    "moderation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "1.18.0",
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "pg": "8.21.0",
    "undici": "8.5.0",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/express": "5.0.6",
    "@types/node": "25.9.3",
    "@types/pg": "8.20.0",
    "eslint": "10.5.0",
    "globals": "17.6.0",
    "nodemon": "3.1.14",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  },
  "overrides": {
    "minimatch": "10.2.4",
    "follow-redirects": "1.16.0",
    "postcss": "8.5.10",
    "discord.js": {
      "undici": "^6.27.0"
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.12.1"
  }
}
